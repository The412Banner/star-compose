<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <CheckBox
            android:id="@+id/CBShowFPS"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show FPS" />

        <CheckBox
            android:id="@+id/CBShowCPULoad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show CPU Temperature" />

        <CheckBox
            android:id="@+id/CBShowGPULoad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show GPU Load" />

        <CheckBox
            android:id="@+id/CBShowRAM"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show RAM Usage" />

        <CheckBox
            android:id="@+id/CBShowRenderer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Renderer/GPU Name" />

        <CheckBox
            android:id="@+id/CBShowBatteryTemp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Battery Temperature" />

        <CheckBox
            android:id="@+id/CBShowBatteryVoltage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Battery Voltage" />

    </LinearLayout>
</ScrollView>
